# Copy to .env and fill in the values. `docker compose up` reads this file.

# ── Public URLs ───────────────────────────────────────────────────────────
# These must match where mgt-be / mgt-ui actually serve from. The OAuth
# callback URL on GitHub must equal MGT_BASE_URL + /auth/github/callback.
#
# mgt-be exposes two listeners:
#   :8080 — REST API used by mgt-ui (and the OAuth/webhook callbacks)
#   :9090 — gRPC API used by mgt-cli
MGT_BASE_URL=http://localhost:8080
MGT_UI_BASE_URL=http://localhost:3000

# ── Secrets (REQUIRED) ────────────────────────────────────────────────────
# Both must be at least 32 characters. Generate with:
#   openssl rand -base64 48 | tr -d '\n'
MGT_MASTER_KEY=replace-me-with-a-32-char-or-longer-random-string
SESSION_SECRET=replace-me-with-a-32-char-or-longer-random-string

# ── Postgres ──────────────────────────────────────────────────────────────
POSTGRES_PASSWORD=mgt

# ── GitHub OAuth App ──────────────────────────────────────────────────────
# Create at https://github.com/settings/developers (OAuth Apps).
#   Homepage URL:               $MGT_UI_BASE_URL
#   Authorization callback URL: $MGT_BASE_URL/auth/github/callback
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Set this to the same secret you configure on each repository's webhook.
# `docker compose up` will register hooks against /webhooks/github.
GITHUB_WEBHOOK_SECRET=

# ── LLM (optional) ────────────────────────────────────────────────────────
# Leave LLM_API_KEY blank to disable AI describe / --ai flag. POST
# /pulls/{n}/describe will return 412 in that case.
LLM_API_KEY=
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o-mini
